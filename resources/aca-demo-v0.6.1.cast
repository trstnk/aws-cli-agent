[94.529292, "o", "\u001b[7maca list account ids for *kubernetes*\u001b[27m"]
[95.78957, "o", "\r\u001b[C\u001b[Caca list account ids for *kubernetes*\r\n\u001b[?2004l\r"]
[103.48377, "o", "\r\n"]
[103.4842, "o", "\u001b[1m  Reason: \u001b[22mList AWS account IDs for all *kubernetes* profiles\r\n\u001b[1m  Script:\u001b[22m\r\n"]
[103.485368, "o", "\u001b[32m    \u001b[39m\r\n\u001b[32m    set -euo pipefail\u001b[39m\r\n\u001b[32m    \u001b[39m\r\n\u001b[32m    profiles=(\u001b[39m\r\n\u001b[32m      abc-kubernetes-platform-dev\u001b[39m\r\n\u001b[32m      abc-kubernetes-platform-int\u001b[39m\r\n\u001b[32m      abc-kubernetes-platform-stg\u001b[39m\r\n\u001b[32m      abc-kubernetes-platform-prod\u001b[39m\r\n\u001b[32m    )\u001b[39m\r\n\u001b[32m    \u001b[39m\r\n\u001b[32m    printf \"%-40s %s\\n\" \"PROFILE\" \"ACCOUNT_ID\"\u001b[39m\r\n\u001b[32m    printf \"%-40s %s\\n\" \"-------\" \"----------\"\u001b[39m\r\n\u001b[32m    \u001b[39m\r\n\u001b[32m    for profile in \"${profiles[@]}\"; do\u001b[39m\r\n\u001b[32m      account_id=$(\u001b[39m\u001b[7m\u001b[94maws sts get-caller-identity\u001b[39m\u001b[27m\u001b[32m --profile \"$profile\" --query Account --output text 2\u001b[39m\u001b[32m>/dev/null || echo \"ERROR\")\u001b[39m\r\n\u001b[32m      printf \"%-40s %s\\n\" \"$profile\" \"$account_id\"\u001b[39m\r\n\u001b[32m    done\u001b[39m\r\n\u001b[32m    \u001b[39m\r\n"]
[103.501403, "o", "\u001b[34m?\u001b[39m \u001b[1mWhat would you like to do with this script?\u001b[22m\r\n\u001b[36m❯ Execute now\u001b[39m\r\n  Save to disk (/home/trstnk/aca/.local/share/aws-cli-agent/scripts/2026-06-05_12-40-\r\n01_list-aws-account-ids-for-all-kubernetes-.sh)\r\n  Cancel\r\n\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
